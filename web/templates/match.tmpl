{{define "matchLayout"}}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>match-history{{if .GameModeLabel}} — {{.GameModeLabel}}{{end}}</title>
<link rel="stylesheet" href="{{styleURL}}">
</head>
<body>
{{template "topbar" .}}
<main>
{{template "matchContent" .}}
</main>
</body>
</html>
{{end}}

{{define "matchContent"}}
<a class="back-link" href="/?q={{.Query}}&amp;region={{.Region}}">&larr; back to match-history</a>

{{if .Error}}
<div class="error">{{.Error}}</div>
{{else}}
<div class="detail-meta">
  <span class="mode">{{.GameModeLabel}}</span>
  <span class="muted">{{.DurationLabel}}</span>
  <span class="muted">{{.TimeAgoLabel}}</span>
</div>

{{template "teamGroup" .Team1}}
{{template "teamGroup" .Team2}}
{{end}}
{{end}}

{{define "teamGroup"}}
<div class="section-label">{{if .Win}}victory{{else}}defeat{{end}}<span class="rule"></span></div>
<div class="panel">
  <div class="team-head {{if .Win}}win{{else}}loss{{end}}">
    <span>team totals</span>
    <span class="totals">{{.TotalKills}}/{{.TotalDeaths}}/{{.TotalAssists}} &middot; {{.TotalGold}}g</span>
  </div>
  <table class="scoretable">
    <colgroup>
      <col style="width:auto">
      <col style="width:100px">
      <col style="width:56px">
      <col style="width:80px">
      <col style="width:170px">
      <col style="width:150px">
    </colgroup>
    <thead><tr><th>player</th><th>kda</th><th>cs</th><th>gold</th><th>damage</th><th>items</th></tr></thead>
    <tbody>
      {{range .Players}}
      <tr{{if .IsHighlighted}} class="me"{{end}}>
        <td>
          <div class="player-inner">
            <img class="champ-icon-img" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
            <div class="spell-col">
              {{range .SummonerSpellIconURLs}}<img class="spell-icon-img" src="{{.}}" alt="">{{end}}
            </div>
            <a class="riot-id" href="/?q={{.RiotID}}&amp;region={{.Region}}">{{.RiotID}}</a>
          </div>
        </td>
        <td class="num-cell">{{.Kills}}/{{.Deaths}}/{{.Assists}}</td>
        <td class="num-cell">{{.CS}}</td>
        <td class="num-cell">{{.Gold}}</td>
        <td class="dmg-cell">
          <div class="dmg-inner">
            <div class="dmg-bar-track"><div class="dmg-bar-fill" style="width:{{.DamagePercent}}%"></div></div>
            <span class="dmg-num">{{.Damage}}</span>
          </div>
        </td>
        <td class="items-cell">
          <div class="items-inner">
            {{range .ItemIconURLs}}{{if .}}<img class="item-slot-img" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
          </div>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
</div>
{{end}}
