{{define "matchLayout"}}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Match Detail{{if .GameModeLabel}} — {{.GameModeLabel}}{{end}}</title>
<link rel="stylesheet" href="/static/style.css">
</head>
<body>
{{template "topbar" .}}
<main>
{{template "matchContent" .}}
</main>
</body>
</html>
{{end}}

{{define "matchContent"}}
<a class="back-link" href="/?q={{.Query}}&amp;region={{.Region}}">&larr; Back to Match History</a>

{{if .Error}}
<div class="error">{{.Error}}</div>
{{else}}
<div class="detail-meta">
  <span class="mode">{{.GameModeLabel}}</span>
  <span class="muted">{{.DurationLabel}}</span>
  <span class="muted">{{.TimeAgoLabel}}</span>
</div>

<div class="scoreboard">
  {{template "teamTable" .Team1}}
  {{template "teamTable" .Team2}}
</div>
{{end}}
{{end}}

{{define "teamTable"}}
<div class="team">
  <div class="team-head {{if .Win}}win{{else}}loss{{end}}">
    <span>{{if .Win}}Victory{{else}}Defeat{{end}}</span>
    <span>Team totals: {{.TotalKills}} / {{.TotalDeaths}} / {{.TotalAssists}} &middot; {{.TotalGold}} gold</span>
  </div>
  <table>
    <thead>
      <tr>
        <th>Player</th>
        <th>KDA</th>
        <th>CS</th>
        <th>Gold</th>
        <th>Damage</th>
        <th>Items</th>
      </tr>
    </thead>
    <tbody>
      {{range .Players}}
      <tr{{if .IsHighlighted}} class="me"{{end}}>
        <td class="player-cell">
          <img class="champ-icon" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
          <div class="spell-col">
            {{range .SummonerSpellIconURLs}}<img class="spell-icon" src="{{.}}" alt="">{{end}}
          </div>
          <span class="riot-id">{{.RiotID}}</span>
        </td>
        <td class="num-cell">{{.Kills}} / {{.Deaths}} / {{.Assists}}</td>
        <td class="num-cell">{{.CS}}</td>
        <td class="num-cell">{{.Gold}}</td>
        <td class="dmg-cell">
          <div class="dmg-bar-track"><div class="dmg-bar-fill" style="width:{{.DamagePercent}}%"></div></div>
          <span class="dmg-num">{{.Damage}}</span>
        </td>
        <td class="items-cell">
          {{range .ItemIconURLs}}{{if .}}<img class="item-slot" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
</div>
{{end}}
