{{define "matchLayout"}}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Match Detail{{if .GameModeLabel}} — {{.GameModeLabel}}{{end}}</title>
<link rel="stylesheet" href="/static/style.css">
</head>
<body>
{{template "topbar" .}}
<main>
{{template "matchContent" .}}
</main>
</body>
</html>
{{end}}

{{define "matchContent"}}
<a class="back-link" href="/?q={{.Query}}&amp;region={{.Region}}">&larr; Back to Match History</a>

{{if .Error}}
<div class="error">{{.Error}}</div>
{{else}}
<div class="detail-meta">
  <span class="mode">{{.GameModeLabel}}</span>
  <span class="muted">{{.DurationLabel}}</span>
  <span class="muted">{{.TimeAgoLabel}}</span>
</div>

{{template "teamGroup" .Team1}}
{{template "teamGroup" .Team2}}
{{end}}
{{end}}

{{define "teamGroup"}}
<div class="group-label">{{if .Win}}Victory{{else}}Defeat{{end}}</div>
<div class="group">
  <div class="team-head {{if .Win}}win{{else}}loss{{end}}">
    <span>Team totals</span>
    <span class="totals">{{.TotalKills}} / {{.TotalDeaths}} / {{.TotalAssists}} &middot; {{.TotalGold}} gold</span>
  </div>
  {{range .Players}}
  <div class="row player-row{{if .IsHighlighted}} me{{end}}">
    <div class="player-cell">
      <img class="champ-icon-img" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
      <div class="spell-col">
        {{range .SummonerSpellIconURLs}}<img class="spell-icon-img" src="{{.}}" alt="">{{end}}
      </div>
      <a class="riot-id" href="/?q={{.RiotID}}&amp;region={{.Region}}">{{.RiotID}}</a>
    </div>
    <div class="player-stats">
      <div class="col-kda"><span class="lbl">KDA</span>{{.Kills}} / {{.Deaths}} / {{.Assists}}</div>
      <div class="col-cs"><span class="lbl">CS</span>{{.CS}}</div>
      <div class="col-gold"><span class="lbl">Gold</span>{{.Gold}}</div>
      <div class="dmg-wrap">
        <div class="dmg-bar-track"><div class="dmg-bar-fill" style="width:{{.DamagePercent}}%"></div></div>
        <span>{{.Damage}}</span>
      </div>
      <div class="items-inline">
        {{range .ItemIconURLs}}{{if .}}<img class="item-slot-img" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
      </div>
    </div>
  </div>
  {{end}}
</div>
{{end}}
