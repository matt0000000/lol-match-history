{{define "themeInit"}}
<script>(function(){try{var t=localStorage.getItem('theme');if(t){document.documentElement.setAttribute('data-theme',t);}}catch(e){}})();</script>
{{end}}

{{define "topbar"}}
<header>
  <div class="header-inner">
    <div class="prompt-line">
      <span class="prompt-sigil">❯</span>
      <span class="wordmark">match-history<span class="dim"> — riot match lookup</span></span>
      <button type="button" class="btn theme-toggle" onclick="toggleTheme()" aria-label="Toggle color theme">[ theme ]</button>
    </div>
    <form class="search-form" method="get" action="/">
      <span class="sigil">$</span>
      <select name="region">
        <option value="na1" {{if eq .Region "na1"}}selected{{end}}>na1</option>
        <option value="euw1" {{if eq .Region "euw1"}}selected{{end}}>euw1</option>
        <option value="eun1" {{if eq .Region "eun1"}}selected{{end}}>eun1</option>
        <option value="kr" {{if eq .Region "kr"}}selected{{end}}>kr</option>
        <option value="jp1" {{if eq .Region "jp1"}}selected{{end}}>jp1</option>
        <option value="br1" {{if eq .Region "br1"}}selected{{end}}>br1</option>
        <option value="la1" {{if eq .Region "la1"}}selected{{end}}>la1</option>
        <option value="la2" {{if eq .Region "la2"}}selected{{end}}>la2</option>
        <option value="oc1" {{if eq .Region "oc1"}}selected{{end}}>oc1</option>
        <option value="tr1" {{if eq .Region "tr1"}}selected{{end}}>tr1</option>
        <option value="ru" {{if eq .Region "ru"}}selected{{end}}>ru</option>
      </select>
      <input type="text" name="q" placeholder="search name#tag" value="{{.Query}}" autocomplete="off">
      <button type="submit" class="btn">[ search ]</button>
    </form>
  </div>
</header>
<script>
function applyTheme(t){
  document.documentElement.setAttribute('data-theme', t);
  try { localStorage.setItem('theme', t); } catch (e) {}
  var b = document.querySelector('.theme-toggle');
  if (b) b.textContent = t === 'dark' ? '[ light ]' : '[ dark ]';
}
function currentTheme(){
  var t = document.documentElement.getAttribute('data-theme');
  if (t) return t;
  return (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ? 'light' : 'dark';
}
function toggleTheme(){ applyTheme(currentTheme() === 'dark' ? 'light' : 'dark'); }
(function(){
  var b = document.querySelector('.theme-toggle');
  if (b) b.textContent = currentTheme() === 'dark' ? '[ light ]' : '[ dark ]';
})();
</script>
{{end}}

{{define "layout"}}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>match-history{{if .Profile}} — {{.Profile.GameName}}#{{.Profile.TagLine}}{{end}}</title>
{{template "themeInit" .}}
<link rel="stylesheet" href="{{styleURL}}">
</head>
<body>
{{template "topbar" .}}
<main>
{{template "content" .}}
</main>
</body>
</html>
{{end}}
