{{define "content"}}
{{if .Error}}
<div class="error">{{.Error}}</div>
{{end}}

{{if .Profile}}
<section class="profile">
  <img class="profile-icon" src="{{.Profile.ProfileIconURL}}" alt="">
  <div>
    <div class="profile-name">{{.Profile.GameName}}<span class="tag">#{{.Profile.TagLine}}</span></div>
    <div class="profile-level">Level {{.Profile.SummonerLevel}}</div>
  </div>
</section>

<div class="matches">
{{range .Matches}}
  <a class="match-row {{if .Win}}win{{else}}loss{{end}}" href="/match/{{.MatchID}}?me={{$.Query}}">
    <div class="result-block">
      <div class="result-label">{{if .Win}}Victory{{else}}Defeat{{end}}</div>
      <div class="result-sub">{{.GameModeLabel}}</div>
      <div class="result-sub">{{.TimeAgoLabel}}</div>
    </div>

    <div class="champ-block">
      <img class="champ-icon" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
      <div class="spell-col">
        {{range .SummonerSpellIconURLs}}<img class="spell-icon" src="{{.}}" alt="">{{end}}
      </div>
    </div>

    <div class="items-row">
      {{range .ItemIconURLs}}{{if .}}<img class="item-slot" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
    </div>

    <div class="stat-cluster">
      <div class="stat"><span class="v">{{.Kills}} / {{.Deaths}} / {{.Assists}}</span><span class="k">KDA</span></div>
      <div class="stat"><span class="v">{{.CS}}</span><span class="k">CS</span></div>
      <div class="stat gold"><span class="v">{{.Gold}}</span><span class="k">Gold</span></div>
    </div>
  </a>
{{end}}
</div>
{{end}}
{{end}}
