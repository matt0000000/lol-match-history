{{define "content"}}
{{if .Error}}
<div class="error">{{.Error}}</div>
{{end}}

{{if .Profile}}
<div class="profile">
  <img class="avatar-img" src="{{.Profile.ProfileIconURL}}" alt="">
  <div>
    <div class="profile-name">{{.Profile.GameName}}<span class="tag">#{{.Profile.TagLine}}</span></div>
    <div class="profile-level">Level {{.Profile.SummonerLevel}}</div>
  </div>
  <div class="update-block">
    <form method="get" action="/">
      <input type="hidden" name="q" value="{{.Query}}">
      <input type="hidden" name="region" value="{{.Region}}">
      <input type="hidden" name="refresh" value="1">
      <button type="submit" class="update-btn">Update</button>
    </form>
    <div class="last-updated">{{.LastUpdatedLabel}}</div>
  </div>
</div>

<div class="group-label">Ranked</div>
<div class="group">
  <div class="row rank-row">
    <div class="rank-queue">Solo/Duo</div>
    <div class="rank-detail">
      {{if .Profile.SoloRank}}<b>{{.Profile.SoloRank.Tier}} {{.Profile.SoloRank.Division}}</b> &middot; {{.Profile.SoloRank.LeaguePoints}} LP &middot; {{.Profile.SoloRank.Wins}}W {{.Profile.SoloRank.Losses}}L &middot; {{.Profile.SoloRank.WinRatePercent}}%{{else}}Unranked{{end}}
    </div>
  </div>
  <div class="row rank-row">
    <div class="rank-queue">Flex 5v5</div>
    <div class="rank-detail">
      {{if .Profile.FlexRank}}<b>{{.Profile.FlexRank.Tier}} {{.Profile.FlexRank.Division}}</b> &middot; {{.Profile.FlexRank.LeaguePoints}} LP &middot; {{.Profile.FlexRank.Wins}}W {{.Profile.FlexRank.Losses}}L &middot; {{.Profile.FlexRank.WinRatePercent}}%{{else}}Unranked{{end}}
    </div>
  </div>
</div>

<div class="group-label">Recent Matches</div>
<div class="group">
{{range .Matches}}
  <a class="row match-row {{if .Win}}win{{else}}loss{{end}}" href="/match/{{.MatchID}}?me={{$.Query}}">
    <div class="result-dot"></div>
    <div class="result-block">
      <div class="result-label">{{if .Win}}Victory{{else}}Defeat{{end}}</div>
      <div class="result-sub">{{.GameModeLabel}}</div>
      <div class="result-sub">{{.TimeAgoLabel}}</div>
    </div>

    <div class="champ-block">
      <img class="champ-icon-img" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
      <div class="spell-col">
        {{range .SummonerSpellIconURLs}}<img class="spell-icon-img" src="{{.}}" alt="">{{end}}
      </div>
    </div>

    <div class="items-row">
      {{range .ItemIconURLs}}{{if .}}<img class="item-slot-img" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
    </div>

    <div class="stat-cluster">
      <div class="stat"><span class="v">{{.Kills}} / {{.Deaths}} / {{.Assists}}</span><span class="k">KDA</span></div>
      <div class="stat"><span class="v">{{.CS}}</span><span class="k">CS</span></div>
      <div class="stat gold"><span class="v">{{.Gold}}</span><span class="k">Gold</span></div>
    </div>
  </a>
{{end}}
</div>
{{end}}
{{end}}
