{{define "content"}}
{{if .Error}}
<div class="error">{{.Error}}</div>
{{end}}

{{if .Profile}}
<section class="profile">
  <img class="profile-icon" src="{{.Profile.ProfileIconURL}}" alt="">
  <div class="profile-info">
    <div class="profile-name">{{.Profile.GameName}}<span class="tag">#{{.Profile.TagLine}}</span></div>
    <div class="profile-level">Level {{.Profile.SummonerLevel}}</div>
  </div>

  <div class="ranks">
    <div class="rank-card">
      <div class="rank-queue">Solo/Duo</div>
      {{if .Profile.SoloRank}}
      <div class="rank-tier">{{.Profile.SoloRank.Tier}} {{.Profile.SoloRank.Division}}</div>
      <div class="rank-wl">{{.Profile.SoloRank.LeaguePoints}} LP &middot; {{.Profile.SoloRank.Wins}}W {{.Profile.SoloRank.Losses}}L &middot; {{.Profile.SoloRank.WinRatePercent}}%</div>
      {{else}}
      <div class="rank-unranked">Unranked</div>
      {{end}}
    </div>
    <div class="rank-card">
      <div class="rank-queue">Flex 5v5</div>
      {{if .Profile.FlexRank}}
      <div class="rank-tier">{{.Profile.FlexRank.Tier}} {{.Profile.FlexRank.Division}}</div>
      <div class="rank-wl">{{.Profile.FlexRank.LeaguePoints}} LP &middot; {{.Profile.FlexRank.Wins}}W {{.Profile.FlexRank.Losses}}L &middot; {{.Profile.FlexRank.WinRatePercent}}%</div>
      {{else}}
      <div class="rank-unranked">Unranked</div>
      {{end}}
    </div>
  </div>

  <div class="update-block">
    <form method="get" action="/">
      <input type="hidden" name="q" value="{{.Query}}">
      <input type="hidden" name="region" value="{{.Region}}">
      <input type="hidden" name="refresh" value="1">
      <button type="submit" class="update-btn">Update</button>
    </form>
    <div class="last-updated">{{.LastUpdatedLabel}}</div>
  </div>
</section>

<div class="matches">
{{range .Matches}}
  <a class="match-row {{if .Win}}win{{else}}loss{{end}}" href="/match/{{.MatchID}}?me={{$.Query}}">
    <div class="result-block">
      <div class="result-label">{{if .Win}}Victory{{else}}Defeat{{end}}</div>
      <div class="result-sub">{{.GameModeLabel}}</div>
      <div class="result-sub">{{.TimeAgoLabel}}</div>
    </div>

    <div class="champ-block">
      <img class="champ-icon" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
      <div class="spell-col">
        {{range .SummonerSpellIconURLs}}<img class="spell-icon" src="{{.}}" alt="">{{end}}
      </div>
    </div>

    <div class="items-row">
      {{range .ItemIconURLs}}{{if .}}<img class="item-slot" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
    </div>

    <div class="stat-cluster">
      <div class="stat"><span class="v">{{.Kills}} / {{.Deaths}} / {{.Assists}}</span><span class="k">KDA</span></div>
      <div class="stat"><span class="v">{{.CS}}</span><span class="k">CS</span></div>
      <div class="stat gold"><span class="v">{{.Gold}}</span><span class="k">Gold</span></div>
    </div>
  </a>
{{end}}
</div>
{{end}}
{{end}}
