{{define "content"}}
{{if .Error}}
<div class="error">{{.Error}}</div>
{{end}}

{{if .Profile}}
<div class="profile">
  <img class="avatar-img" src="{{.Profile.ProfileIconURL}}" alt="">
  <div>
    <div class="profile-name">{{.Profile.GameName}}<span class="tag">#{{.Profile.TagLine}}</span></div>
    <div class="profile-level">level {{.Profile.SummonerLevel}}</div>
  </div>
  <div class="update-block">
    <form method="get" action="/">
      <input type="hidden" name="q" value="{{.Query}}">
      <input type="hidden" name="region" value="{{.Region}}">
      <input type="hidden" name="refresh" value="1">
      <button type="submit" class="btn muted">[ update ]</button>
    </form>
    <div class="last-updated">{{.LastUpdatedLabel}}</div>
  </div>
</div>

<div class="section-label">ranked<span class="rule"></span></div>
<div class="panel">
  <div class="panel-row rank-row">
    <div class="rank-queue">solo/duo</div>
    <div class="rank-detail">
      {{if .Profile.SoloRank}}<b>{{.Profile.SoloRank.Tier}} {{.Profile.SoloRank.Division}}</b> {{.Profile.SoloRank.LeaguePoints}}lp &middot; {{.Profile.SoloRank.Wins}}w {{.Profile.SoloRank.Losses}}l &middot; {{.Profile.SoloRank.WinRatePercent}}%{{else}}unranked{{end}}
    </div>
  </div>
  <div class="panel-row rank-row">
    <div class="rank-queue">flex 5v5</div>
    <div class="rank-detail">
      {{if .Profile.FlexRank}}<b>{{.Profile.FlexRank.Tier}} {{.Profile.FlexRank.Division}}</b> {{.Profile.FlexRank.LeaguePoints}}lp &middot; {{.Profile.FlexRank.Wins}}w {{.Profile.FlexRank.Losses}}l &middot; {{.Profile.FlexRank.WinRatePercent}}%{{else}}unranked{{end}}
    </div>
  </div>
</div>

<div class="section-label">recent matches<span class="rule"></span></div>
<div class="panel">
{{range .Matches}}
  <a class="panel-row match-row {{if .Win}}win{{else}}loss{{end}}" href="/match/{{.MatchID}}?me={{$.Query}}">
    <span class="tag-badge">{{if .Win}}WIN{{else}}LOSS{{end}}</span>
    <div class="result-block">{{.GameModeLabel}}<br>{{.TimeAgoLabel}}</div>

    <div class="champ-block">
      <img class="champ-icon-img" src="{{.ChampionIconURL}}" alt="{{.ChampionName}}">
      <div class="spell-col">
        {{range .SummonerSpellIconURLs}}<img class="spell-icon-img" src="{{.}}" alt="">{{end}}
      </div>
    </div>

    <div class="items-row">
      {{range .ItemIconURLs}}{{if .}}<img class="item-slot-img" src="{{.}}" alt="">{{else}}<span class="item-slot empty"></span>{{end}}{{end}}
    </div>

    <div class="stat-cluster">
      <div class="stat"><span class="v">{{.Kills}}/{{.Deaths}}/{{.Assists}}</span><br><span class="k">kda</span></div>
      <div class="stat"><span class="v">{{.CS}}</span><br><span class="k">cs</span></div>
      <div class="stat gold"><span class="v">{{.Gold}}</span><br><span class="k">gold</span></div>
    </div>
  </a>
{{end}}
</div>
{{end}}
{{end}}
